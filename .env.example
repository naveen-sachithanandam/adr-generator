# Copy to .env and adjust. Never commit real secrets.

# Anthropic — used when LLM backend is Anthropic, or Auto when this is set
# ANTHROPIC_API_KEY=
# ADR_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama — used when LLM backend is Ollama, or Auto when no Anthropic key
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
